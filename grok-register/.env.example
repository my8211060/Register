# YesCaptcha（必填）
YESCAPTCHA_KEY="your_yescaptcha_key"

# 邮箱提供商：gptmail / luckmail / mailnest
EMAIL_PROVIDER="gptmail"

# Grok 注册线程数（可选）
THREADS="1"

# LuckMail 配置（仅在 EMAIL_PROVIDER=luckmail 时需要）
# LUCKMAIL_BASE_URL 已内置为 https://mails.luckyous.com，只有使用别的站点时才需要覆盖
# LUCKMAIL_BASE_URL="https://mails.luckyous.com"
LUCKMAIL_API_KEY="your_luckmail_api_key"
LUCKMAIL_API_SECRET=""
LUCKMAIL_USE_HMAC="false"
LUCKMAIL_PROJECT_CODE="grok"
LUCKMAIL_EMAIL_TYPE="ms_imap"
LUCKMAIL_DOMAIN="outlook.com"

# MailNest 配置（仅在 EMAIL_PROVIDER=mailnest 时需要）
# 获取 apikey：https://mailnest.top/account
# 获取项目代码：https://mailnest.top/buy-email 默认为 x-ai001 可直接使用
MAILNEST_API_KEY="your_mailnest_api_key"
MAILNEST_PROJECT_CODE="x-ai001"

# 可选代理示例（如需可自行启用）
# HTTP_PROXY="http://127.0.0.1:7890"
# HTTPS_PROXY="http://127.0.0.1:7890"
